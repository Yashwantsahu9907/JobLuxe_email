# ========================================================
# ENVIRONMENT VARIABLES CONFIGURATION (EXAMPLE)
# ========================================================
# Note: For production deployment (e.g. Render, Vercel),
# set these exact variables in your hosting environment.

NODE_ENV=production
PORT=5000

# The URL of your deployed frontend (e.g., https://your-app.vercel.app)
# For local development, it can be http://localhost:5173
FRONTEND_URL=http://localhost:5173

# MongoDB Connection String (Atlas or Local)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/yourDatabaseName?retryWrites=true&w=majority

# ========================================================
# AUTHENTICATION CONFIGURATION
# ========================================================

# The fixed admin credentials to log into the dashboard
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_admin_password

# A strong secret key used for signing JWT tokens
JWT_SECRET=your_super_secret_jwt_key_here

# ========================================================
# EMAIL / SMTP CONFIGURATION
# ========================================================

# Only required if you're using static .env fallback.
# However, this application is configured to use Database-stored Dynamic App Passwords.
# You can leave this out if you're solely utilizing the Admin Dashboard to setup SMTP accounts!
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_16_character_app_password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Rate Limiting configuration to prevent blocks from Gmail and others
EMAIL_DELAY_MS=3000
