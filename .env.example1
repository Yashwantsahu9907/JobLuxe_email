# --- SERVER CONFIGURATION ---
PORT=5000
NODE_ENV=production
# Set to 'true' if you want the backend to serve the frontend locally/in production
SERVE_FRONTEND=true

# --- DATABASE CONFIGURATION ---
# MongoDB Atlas Connection URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/your-db-name?retryWrites=true&w=majority

# --- AUTHENTICATION ---
# Random string for signing JWT tokens
JWT_SECRET=your_jwt_secret_here

# --- ADMIN CREDENTIALS ---
# Credentials for the application dashboard
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_password

# --- EMAIL (SMTP) CONFIGURATION ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Your Gmail address
SMTP_USER=your_email@gmail.com
# Your 16-character Gmail App Password
SMTP_PASS=your_app_password

# --- CAMPAIGN CONFIGURATION ---
# Optional: Delay between sending each email in milliseconds
EMAIL_DELAY_MS=3000

# --- FRONTEND CONFIGURATION ---
# The URL of your deployed application
FRONTEND_URL=https://your-app-name.onrender.com
# For Vite during build (if not using single-service model)
VITE_API_BASE_URL=
